# ================================================================
# Configuration Plateforme de Surveillance Réseau - GLENZ Stack
# (Grafana-Logstash-Elasticsearch-Nginx-Zeek)
# ================================================================

# Interface réseau à surveiller
# Trouvez votre interface avec: ip link show
# Exemples courants:
#   - ens33, ens192 (VMware)
#   - eth0, eth1 (Serveurs physiques)
#   - enp0s3 (VirtualBox)
#   - wlan0 (WiFi)
CAPTURE_INTERFACE=ens33

# Mémoire allouée à Elasticsearch
# Recommandé: 2g (minimum: 1g, optimal: 4g)
ES_JAVA_OPTS=-Xms2g -Xmx2g

# Mémoire allouée à Logstash
# Recommandé: 1g (minimum: 512m, optimal: 2g)
LOGSTASH_JAVA_OPTS=-Xms1g -Xmx1g

# Mot de passe Grafana
# Par défaut: admin/admin (changez en production)
GRAFANA_PASSWORD=admin

# Rétention des données (en jours)
PCAP_RETENTION_DAYS=7
LOGS_RETENTION_DAYS=30

# Configuration Dumpcap (capture PCAP)
# Taille maximale par fichier PCAP (en MB)
PCAP_MAX_SIZE=1000
# Nombre de fichiers dans le ring buffer
PCAP_FILES=10
